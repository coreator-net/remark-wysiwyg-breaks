{
  "name": "@coreator/remark-wysiwyg-breaks",
  "version": "1.0.0",
  "description": "A remark plugin that preserves line breaks and empty lines as users intended (WYSIWYG)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "remark",
    "remark-plugin",
    "markdown",
    "wysiwyg",
    "line-break",
    "hard-break",
    "preserve-breaks"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "peerDependencies": {
    "unified": ">=10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "unified": "^11.0.0",
    "vitest": "^1.0.0"
  }
}
